# ── Outputs & cache ───────────────────────────────────────────────────────────
outputs/.instore_cache/
outputs/.llm_cache/
outputs/models/
outputs/nba_results*.xlsx
!outputs/nba_results_llm.xlsx
outputs/~$*.xlsx
# File demo được commit để máy khác chạy được ngay cả 2 luồng:
# outputs/instore_scripts.json  ← đã được track (Luồng 2 in-store)
# outputs/nba_results_llm.xlsx  ← đã được track (Luồng 1 outbound)

# ── Data (bỏ file lock Excel, giữ lại file demo) ────────────────────────────
data/~$*.xlsx
data/customer_data_poc_enhanced_2.xlsx
data/customer_data_poc_enhanced_v2.xlsx
# File demo nhỏ được commit để máy khác có thể chạy ngay:
# data/customer_data_poc_enhanced.xlsx  ← đã được track

# ── Temporary Excel lock files ────────────────────────────────────────────────
~$*.xlsx
~$*.docx

